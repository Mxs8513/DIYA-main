# ── D.I.Y.A backend configuration ───────────────────────────────────────────
# Copy this file to `.env` and fill in real values:  cp .env.example .env

# Port the API listens on (frontend dev proxy expects 3001)
PORT=3001

# Secret used to sign JWTs. MUST be set to a strong, unique value in production —
# the server refuses to boot in production (NODE_ENV=production) without it.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production

# Anthropic API key. OPTIONAL for local demos — without it the app still runs
# and uses deterministic fallbacks (keyword topic classification, template
# answers, etc.). Set it to enable real AI answers, confidence scoring,
# analysis, and self-check grading.
ANTHROPIC_API_KEY=

# ── AI usage caps (defense-in-depth cost controls) ──────────────────────────
# These protect a PUBLIC deploy from burning Anthropic credits. They are NOT a
# substitute for setting a hard spend limit in the Anthropic Console — do both.
#
# Master switch. Even with a key present, NO Anthropic call is made unless this
# is exactly "true". For a public portfolio demo, leave this false.
AI_ENABLED=false
# When true, blocked AI shows: "Public demo mode: live LLM calls are limited…".
AI_PUBLIC_DEMO_MODE=true
# Spend ceilings (USD), computed from the ai_usage_events ledger.
AI_DAILY_BUDGET_USD=0.50
AI_MONTHLY_BUDGET_USD=5.00
# Per-identity daily call caps.
AI_MAX_CALLS_PER_USER_PER_DAY=10
AI_MAX_CALLS_PER_IP_PER_DAY=20
AI_MAX_SELF_CHECKS_PER_USER_PER_DAY=3
AI_MAX_ANALYSIS_CALLS_PER_USER_PER_DAY=5
# Token pricing used to estimate spend (USD per 1,000,000 tokens). Conservative
# Haiku-class defaults; override to match your model's current list price.
AI_INPUT_PRICE_PER_MILLION=1.00
AI_OUTPUT_PRICE_PER_MILLION=5.00

# Allowed CORS origin(s), comma-separated, for deployment. If unset, any
# localhost port is allowed (development default).
# CORS_ORIGIN=https://your-frontend.example.com

# Override the SQLite file location (tests set this to an isolated temp file).
# DB_PATH=/absolute/path/to/diya.db
